# Example environment for local development.
#
# Copy to `.env` on first run and adjust as needed. `.env` is gitignored.
#
# Naming rule (per DESIGN-0001 #Configuration):
#   RFC_API_* .................. config that rfc-api itself defines
#   DATABASE_URL / MEILI_* / OTEL_*  upstream-standard names, unchanged

# -- HTTP listeners -----------------------------------------------------

# Main port: user traffic (/api/v1/*, webhook).
RFC_API_LISTEN=:8080

# Admin port: /healthz, /readyz, /metrics, optional /debug/pprof/*.
# Loopback-bound in dev; NetworkPolicy-gated in prod.
RFC_API_ADMIN_LISTEN=127.0.0.1:8081

# Enable /debug/pprof/* on the admin port. Default false in prod.
# Turn on locally to use the `make pprof-*` targets.
RFC_API_PPROF_ENABLED=true

# -- Logging ------------------------------------------------------------

# slog level: debug | info | warn | error
RFC_API_LOG_LEVEL=info

# slog handler: json | text
RFC_API_LOG_FORMAT=json

# -- Server timeouts ----------------------------------------------------

RFC_API_READ_TIMEOUT=15s
RFC_API_WRITE_TIMEOUT=30s
RFC_API_SHUTDOWN_TIMEOUT=20s

# -- CORS (main port only) ----------------------------------------------

# Comma-separated allow-list. Empty = deny all browser origins.
RFC_API_CORS_ORIGINS=

# -- Rate limit (main port, v1 chain) -----------------------------------

RFC_API_RATE_LIMIT_RPS=50
RFC_API_RATE_LIMIT_BURST=100
RFC_API_RATE_LIMIT_TTL=1h

# -- Secrets (required) -------------------------------------------------

# GitHub webhook HMAC secret. Dev-only placeholder.
RFC_API_WEBHOOK_SECRET=dev-webhook-secret

# -- Observability ------------------------------------------------------

# Head-based OTel sampler ratio (0.0 - 1.0).
RFC_API_TRACE_SAMPLE_RATIO=0.1

# OTLP collector endpoint. Unset = no trace export (dev without
# `make compose-up-obs`). Points at the compose-hosted collector when
# the tracing profile is up.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# -- External deps ------------------------------------------------------

# Postgres DSN. Matches the compose-hosted postgres service.
DATABASE_URL=postgres://rfcapi:rfcapi@localhost:5432/rfcapi?sslmode=disable

# Meilisearch base URL. Compose-hosted instance on the default dev
# port. Unset = defaults to http://localhost:7700.
MEILI_URL=http://localhost:7700

# Meilisearch master key. Must match the value the compose meilisearch
# service boots with (same var name, single source of truth).
MEILI_MASTER_KEY=dev-master-key

# Scoped API keys. Optional in dev (falls back to MEILI_MASTER_KEY);
# required in prod pods where the master key never flows in.
# Provision via the one-time bootstrap (see docs/local-dev.md).
# MEILI_API_KEY=...        # read-only (actions: search)
# MEILI_WRITE_KEY=...      # worker write-scope (documents.*, indexes.*, settings.*)
