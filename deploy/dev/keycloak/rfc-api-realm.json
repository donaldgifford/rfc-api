{
  "realm": "rfc-api",
  "enabled": true,
  "displayName": "rfc-api (dev)",
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "sslRequired": "none",
  "defaultSignatureAlgorithm": "RS256",
  "roles": {
    "realm": [
      {
        "name": "docs:read",
        "description": "Read documents via rfc-api"
      },
      {
        "name": "search",
        "description": "Query /api/v1/search"
      }
    ]
  },
  "clients": [
    {
      "clientId": "rfc-api",
      "name": "rfc-api backend (resource server)",
      "description": "OAuth2/OIDC resource server for the rfc-api backend",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "dev-rfc-api-secret",
      "protocol": "openid-connect",
      "attributes": {
        "access.token.lifespan": "300"
      },
      "defaultClientScopes": [
        "profile",
        "email"
      ]
    },
    {
      "clientId": "rfc-site",
      "name": "rfc-site frontend (public client)",
      "description": "Public OIDC client for the rfc-site SPA",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": [
        "http://localhost:3001/*",
        "http://localhost:5173/*"
      ],
      "webOrigins": [
        "http://localhost:3001",
        "http://localhost:5173"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "access.token.lifespan": "300"
      },
      "defaultClientScopes": [
        "profile",
        "email"
      ]
    }
  ],
  "users": [
    {
      "username": "dev",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Dev",
      "lastName": "User",
      "email": "dev@example.com",
      "credentials": [
        {
          "type": "password",
          "value": "dev",
          "temporary": false
        }
      ],
      "realmRoles": [
        "docs:read",
        "search"
      ]
    }
  ]
}
