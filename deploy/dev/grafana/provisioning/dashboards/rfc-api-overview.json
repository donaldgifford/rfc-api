  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Requests per second by matched route template. Route labels come from the rfc-api routectx (never expanded path values).",
      "fieldConfig": {
        "defaults": {"unit": "reqps"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "expr": "sum by (route) (rate(http_requests_total[1m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "Request rate (by route)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Latency quantiles from the http_request_duration_seconds histogram.",
      "fieldConfig": {
        "defaults": {"unit": "s"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, route) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 {{route}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{route}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, route) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99 {{route}}",
          "refId": "C"
        }
      ],
      "title": "Latency (p50 / p95 / p99, by route)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "4xx and 5xx error rates. 5xx is the alertable tier.",
      "fieldConfig": {
        "defaults": {"unit": "reqps"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "expr": "sum by (route) (rate(http_requests_total{status=~\"5..\"}[1m]))",
          "legendFormat": "5xx {{route}}",
          "refId": "A"
        },
        {
          "expr": "sum by (route) (rate(http_requests_total{status=~\"4..\"}[1m]))",
          "legendFormat": "4xx {{route}}",
          "refId": "B"
        }
      ],
      "title": "Error rate (5xx / 4xx)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "description": "Concurrent in-flight requests by route.",
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {
          "expr": "sum by (route) (http_requests_in_flight)",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ],
      "title": "In-flight requests",
      "type": "timeseries"
    },
    {
